@page "/"
@using System.Security.Claims
@inject IRepository _IRepository
@inject ILoginService _ILoginService
@inject SesionService _SesionService
@inject SweetAlertService _SweetAlertService
@inject NavigationManager _NavigationManager

<PageTitle>Iniciar sesión — Tommy Logistic</PageTitle>

<div class="login-page">
    <div class="login-card">

        <div class="login-header">
            <div class="login-logo">TD</div>
            <h1 class="login-title">TommyLogistic</h1>
            <p class="login-subtitle">Sistema de logística</p>
        </div>

        @if (_error)
        {
            <div class="alert alert-danger" role="alert">
                <span>⚠️</span>
                <span>@(_error ? "Credenciales Inválidas" : "Error al Iniciar Sesión")</span>
            </div>
        }

        <div class="form-group">
            <EditForm Model="loginDTO" OnValidSubmit="LoginAsync">
                <DataAnnotationsValidator />
                <label class="form-label required">Correo electrónico</label>
                <InputText @bind-Value="@loginDTO.Email" type="email"
                           class="@($"form-control {rojete}")"
                           placeholder="usuario@logistic.com"
                           autocomplete="email"
                           inputmode="email"
                           disabled="@_cargando" />
                <ValidationMessage For="@(() => loginDTO.Email)" />
                
                <label class="form-label required">Contraseña</label>
                <InputText @bind-Value="@loginDTO.Password"
                           type="@(_verPassword ? "text" : "password")"
                           class="@($"form-control {rojete}")"
                           autocomplete="current-password"
                           placeholder="••••••••"
                           disabled="@_cargando" />
                <ValidationMessage For="@(() => loginDTO.Password)" />

                <button type="submit" class="btn btn-primary btn-touch">
                    @if (_cargando)
                    {
                        <span class="spinner spinner-sm"></span>
                        <span>Ingresando...</span>
                    }
                    else
                    {
                        <span>Ingresar</span>
                    }
                </button>
            </EditForm>
        </div>

        <p class="login-footer">
            ¿Problemas para acceder? Contacta a tu administrador.
        </p>
    </div>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }
    private LoginDTO loginDTO = new();
    private bool _error;
    private bool _cargando;
    private bool _verPassword;
    private string rojete = string.Empty;


    protected override async Task OnInitializedAsync()
    {
        // if (AuthStateTask != null)
        // {
        //     var authState = await AuthStateTask;
        //     var user = authState.User;

        //     if (user.Identity is not null && user.Identity.IsAuthenticated)
        //     {
        //         await RedirectbyRole(user.FindFirst(ClaimTypes.NameIdentifier)!.Value);
        //     }
        // }
    }

    private async Task LoginAsync()
    {
        _error = false;
        _cargando = true;

        var responseHttp = await _IRepository.PostAsync<LoginDTO, TokenDTO>("api/auth/Login", loginDTO);

        if (responseHttp.Error)
        {
            var message = await responseHttp.GetErrorMessageAsync();
            await _SweetAlertService.FireAsync("Error", message, SweetAlertIcon.Error);
            _error = responseHttp.Error;
            _cargando = false;
            rojete = _error ? "is-invalid" : string.Empty;
            return;
        }

        await _ILoginService.LoginAsync(responseHttp.Response!.Token!);
        string? rol = await _SesionService.GetRolAsync();
        await RedirectbyRole(rol!);
    }

    private async Task RedirectbyRole(string rol)
    {
        if (string.IsNullOrEmpty(rol))
        {
            await _SweetAlertService.FireAsync("Error", "No se pudo determinar el rol del usuario.", SweetAlertIcon.Error);
            _NavigationManager.NavigateTo("/WhoAreYou");
            return;
        }

        switch (rol)
        {
            case "Admin":
                _NavigationManager.NavigateTo("/AdminDashboard");
                break;
            case "Supervisor":
                _NavigationManager.NavigateTo("/SupervisorDashboard");
                break;
            case "Operator":
                _NavigationManager.NavigateTo("/OperatorDashboard");
                break;
            case "Driver":
                _NavigationManager.NavigateTo("/DriverDashboard");
                break;
            case "Client":
                _NavigationManager.NavigateTo("/ClientDashboard");
                break;
            default:
                _NavigationManager.NavigateTo("/WhoAreYou");
                break;
        }
    }
}