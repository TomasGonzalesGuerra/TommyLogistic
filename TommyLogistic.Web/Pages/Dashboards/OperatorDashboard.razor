@page "/OperatorDashboard"
@layout MainLayout
@implements IDisposable
@inject OperatorService _OperatorService
@attribute [Authorize(Roles = nameof(UserEnum.Operator))]

<PageTitle>Panel Operador — Tommy Logistic</PageTitle>

<div class="list-header">
    <h1 class="page-title">Panel de Operaciones</h1>
    @if (_pendientes > 0)
    {
        <span class="badge badge-ausente">
            ⏳ @_pendientes Carga(s) Pendiente(s) de Conclusión
        </span>
    }
</div>

@if (_loading)
{
    <div class="loading-overlay"><div class="spinner"></div></div>
}
else if (!_cargas.Any())
{
    <div class="empty-state">
        <span class="empty-icon">😴</span>
        <p class="text-bold">Sin Cargas activas</p>
    </div>
}
else
{
    <div class="repartidores-grid">
        @foreach (var item in _cargas)
        {
            <div class="rep-card @($"carga--{item.Status}")">
                <!-- Header -->
                <div class="rep-card-header">
                    <div class="rep-avatar"
                         style="@(string.IsNullOrEmpty(item.DriverPhoto)
                             ? $"background:var(--color-primary)"
                             : $"background-image:url('{item.DriverPhoto}')")">
                        @(string.IsNullOrEmpty(item.DriverPhoto) ? Initials(item.DriverName) : "")
                    </div>
                    <div class="rep-info">
                        <span class="rep-nombre">@item.DriverName</span>
                        <span class="text-xs text-muted">🚗 @item.DriverPlaca</span>
                    </div>
                    <BadgeCarga Status="@item.Status" />
                </div>

                <!-- Stats -->
                <div class="rep-stats">
                    <div class="rep-stat-mini">
                        <span class="rep-stat-value">📍 @item.Distrito</span>
                        <span class="rep-stat-label">Distrito</span>
                    </div>
                    <div class="rep-stat-mini">
                        <span class="rep-stat-value" style="color:var(--color-primary)">@item.TotalPedidos</span>
                        <span class="rep-stat-label">Total</span>
                    </div>
                    <div class="rep-stat-mini">
                        <span class="rep-stat-value" style="color:var(--color-success)">@item.Entregados</span>
                        <span class="rep-stat-label">Entregados</span>
                    </div>
                    <div class="rep-stat-mini">
                        <span class="rep-stat-value" style="color:var(--color-warning)">@item.Pendientes</span>
                        <span class="rep-stat-label">Pendientes</span>
                    </div>
                </div>

                <!-- Acciones — dinámicas según status -->
                <div class="rep-acciones">
                    <button @onclick="() => ShowInsideCarga(item.Id)"
                            class="btn btn-outline btn-primary btn-sm">
                        📋 Ver Carga
                    </button>

                    @if (item.Status == CargaStatus.Pendiente)
                    {
                        <button @onclick="() => ShowConcluirCarga(item.Id)"
                                class="btn btn-danger btn-sm">
                            ✅ Concluir
                        </button>
                    }
                </div>
            </div>
        }
    </div>
}

<!-- Modales sin cambios -->

<GenericModal Title="Contenido de la Carga"
              IsVisible="_showInsideCarga"
              OnCancel="CloseInsideCarga">
    <BodyContent>
        <InsideCarga CargaID="_cargaSelected" OnClose="CloseInsideCarga" />
    </BodyContent>
</GenericModal>

<GenericModal Title="Conclusión de Carga"
              IsVisible="_guardandoCarga"
              OnCancel="CloseInsideCarga">
    <BodyContent>
        <div class="p-4">
            <h2 class="text-lg font-bold mb-4">¿Estas Seguro de Concluir esta Carga?</h2>
            <p class="mb-6">Al concluir la Carga, se Cerrarán todos los Pedidos. ¿Deseas Continuar?</p>
            <div class="flex justify-end gap-2">
                <button @onclick="CloseInsideCarga" class="btn btn-outline btn-secondary">Cancelar</button>
                <button @onclick="ConcluirCarga" class="btn btn-danger">Sí, Concluir Carga</button>
            </div>
        </div>
    </BodyContent>
</GenericModal>

@code {
    private List<CargaSummaryDTO> _cargas = [];
    private int _pendientes => _cargas.Count(c => c.Status == CargaStatus.Pendiente);
    private bool _loading;
    private bool _guardandoCarga;
    private bool _showInsideCarga;
    private int _cargaSelected;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _NotificationService.OnNewCarga += HandleNewCarga;
        _NotificationService.OnDashboardUpdate += OnDashboardUpdate;
        _NotificationService.OnSolicituddeConclusion += OnSolicituddeConclusion;
    }

    private async Task LoadAsync()
    {
        _loading = true;

        _cargas = await _OperatorService.GetDashboardAsync();
        // Ordenar: Pendiente primero, luego Activa, resto al final
        _cargas = [.. _cargas.OrderBy(c => c.Status switch
        {
            CargaStatus.Pendiente => 0,
            CargaStatus.Activa              => 1,
            _                               => 2
        })];

        _loading = false;
    }

    private void ShowInsideCarga(int cargaID)
    {
        _cargaSelected = cargaID;
        _showInsideCarga = true;
    }
    private void CloseInsideCarga()
    {
        _cargaSelected = 0;
        _showInsideCarga = false;
        _guardandoCarga = false;
    }

    private void ShowConcluirCarga(int cargaID)
    {
        _cargaSelected = cargaID;
        _guardandoCarga = true;
    }

    private async Task ConcluirCarga()
    {
        string yop = await _SesionService.GetNameAsync() ?? "Yop";
        CargaConcluirDTO DTO = new() { Nota = $"Carga Concluida por {yop.Split('@')[0]}." };
        await _OperatorService.ConcludeCargaAsync(_cargaSelected, DTO);
        _guardandoCarga = false;
    }


    private void OnDashboardUpdate() => InvokeAsync(async () => { await LoadAsync(); StateHasChanged(); });
    private void OnSolicituddeConclusion(string _) => InvokeAsync(async () => { await LoadAsync(); StateHasChanged(); });
    private void HandleNewCarga(NewOrderAssignedDTO _) => InvokeAsync(async () => { await LoadAsync(); StateHasChanged(); });
    private static string Initials(string name)
    {
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}"
            : name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }
    public void Dispose()
    {
        _NotificationService.OnNewCarga -= HandleNewCarga;
        _NotificationService.OnDashboardUpdate -= OnDashboardUpdate;
        _NotificationService.OnSolicituddeConclusion -= OnSolicituddeConclusion;
    }
}
