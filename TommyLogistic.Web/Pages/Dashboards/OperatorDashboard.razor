@page "/OperatorDashboard"
@layout MainLayout
@implements IDisposable
@inject IRepository _Repository
@attribute [Authorize(Roles = nameof(UserEnum.Operator))]

<PageTitle>Panel Operador — Tommy Logistic</PageTitle>

<div class="list-header">
    <h1 class="page-title">Panel de Operaciones</h1>
    @if (_cargas.Count > 0)
    {
        <span class="badge badge-ausente">
            ⏳ @($"{_cargas.Count} Carga(s) Pendiente(s) de Conclusión")
        </span>
    }
</div>

@if (_loading)
{
    <div class="loading-overlay"><div class="spinner"></div></div>
}
else if (!_cargas.Any())
{
    <div class="empty-state">
        <span class="empty-icon">😴</span>
        <p class="text-bold">Sin Cargas</p>
    </div>
}
else
{
    <div class="pedido-cards">
        @foreach (var item in _cargas)
        {
            <div class="pedido-card">
                <div class="pedido-card-top">
                    <div class="carga-card-driver">
                        <div class="timeline-avatar">
                            @Initials(item.DriverName)
                        </div>

                        <div>
                            <p class="text-bold text-sm">@item.DriverName</p>
                            <p class="text-xs text-muted">🚗 @item.DriverPlaca</p>
                        </div>
                    </div>
                    <BadgeCarga Status="@item.Status" />
                </div>

                <div class="pedido-card-meta">
                    <span class="text-xs text-muted">📍 @item.Distrito</span>

                    <span class="text-xs">
                        ✅ @item.TotalPedidos Pedidos
                    </span>

                    <span class="text-xs entregado">
                        ✅ @item.Entregados Entregados
                    </span>

                    <span class="text-xs pendiente">
                        🏭 @item.Pendientes Pendientes
                    </span>
                </div>

                <button @onclick="() => ShowInsideCarga(item.Id)" class="btn btn-success btn-sm w-full mt-4">
                    ✅ Ver Carga
                </button>
            </div>
        }
    </div>
}

<GenericModal Title="Contenido de la Carga"
              IsVisible="_showInsideCarga"
              OnCancel="CloseInsideCarga">
    <BodyContent>
        <InsideCarga CargaID="_cargaSelected" OnClose="CloseInsideCarga" />
    </BodyContent>
</GenericModal>

@code {
    private List<CargaSummaryDTO> _cargas = [];
    private bool _loading;
    private bool _guardando;
    private bool _showInsideCarga;
    private int _cargaSelected = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _NotificationService.OnNewCarga += HandleNewCarga;
        _NotificationService.OnDashboardUpdate += OnDashboardUpdate;
        _NotificationService.OnSolicituddeConclusion += OnSolicituddeConclusion;
    }

    private async Task LoadAsync()
    {
        _loading = true;

        // var r1 = await _Repository.GetAsync<List<DriverOrderDTO>>("api/Orders/GetByStatus?status=Returning");
        // if (!r1.Error) _retornos = r1.Response!;

        var r2 = await _Repository.GetAsync<List<CargaSummaryDTO>>("api/Operators/GetAllCargas");
        if (!r2.Error) _cargas = r2.Response!;

        _loading = false;
    }

    private void ShowInsideCarga(int cargaID)
    {
        _cargaSelected = cargaID;
        _showInsideCarga = true;
    }

    private void CloseInsideCarga()
    {
        _cargaSelected = 0;
        _showInsideCarga = false;
    }

    // private async Task ConfirmarConclusionAsync()
    // {
    //     _guardando = true;

    //     var r = await _Repository.PostAsync($"api/Operators/Concluir/{_cargaAConcluirId}", new CargaConcluirDTO { Nota = _notaConclusion });

    //     if (!r.Error)
    //     {
    //         _mostrarConcluirModal = false;
    //         await LoadAsync();
    //     }

    //     _guardando = false;
    // }

    private void OnDashboardUpdate() => InvokeAsync(async () => { await LoadAsync(); StateHasChanged(); });
    private void OnSolicituddeConclusion(string _) => InvokeAsync(async () => { await LoadAsync(); StateHasChanged(); });
    private void HandleNewCarga(NewOrderAssignedDTO _) => InvokeAsync(async () => { await LoadAsync(); StateHasChanged(); });
    private static string Initials(string name)
    {
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}"
            : name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }
    public void Dispose()
    {
        _NotificationService.OnNewCarga -= HandleNewCarga;
        _NotificationService.OnDashboardUpdate -= OnDashboardUpdate;
        _NotificationService.OnSolicituddeConclusion -= OnSolicituddeConclusion;
    }
}
