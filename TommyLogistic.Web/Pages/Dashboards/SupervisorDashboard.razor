@page "/SupervisorDashboard"
@layout MainLayout
@implements IDisposable
@inject IRepository _Repository
@inject NavigationManager _NavigationManager
@inject NotificationService _NotificationService
@attribute [Authorize(Roles = nameof(UserEnum.Supervisor))]

<PageTitle>Dashboard Supervisor — Tommy Logistic</PageTitle>

<div class="list-header">
    <h1 class="page-title">Panel de Supervisión</h1>
    <button class="btn btn-primary"
            @onclick='() => _NavigationManager.NavigateTo("/supervisor/cargas/nueva")'>
        ➕ Nueva carga
    </button>
</div>

@if (_loading && _cargas is null)
{
    <div class="loading-overlay"><div class="spinner"></div></div>
}
else
{
    <!-- Tabs -->
    <div class="super-tabs">
        @foreach (var tab in _tabs)
        {
            <button class="super-tab @(_tabActivo == tab.Status ? "super-tab--active" : "")"
                    @onclick="() => CambiarTab(tab.Status)">
                @tab.Icono @tab.Label
                @if (tab.Count > 0)
                {
                    <span class="badge badge-encamino">@tab.Count</span>
                }
            </button>
        }
    </div>

    <!-- Lista de cargas -->
    @if (!CargasFiltradas.Any())
    {
        <div class="empty-state">
            <span class="empty-icon">📭</span>
            <p class="text-bold">Sin cargas en este estado</p>
        </div>
    }
    else
    {
        <div class="cargas-grid">
            @foreach (var c in CargasFiltradas)
            {
                <div class="carga-card carga-card--@c.Status.ToString().ToLower()"
                     @onclick="() => AbrirDetalle(c.Id)">

                    <div class="carga-card-header">
                        <div class="carga-card-driver">
                            <div class="timeline-avatar"
                                 style="background:var(--color-primary); width:2rem; height:2rem; font-size:.65rem">
                                @Initials(c.DriverName)
                            </div>
                            <div>
                                <p class="text-bold text-sm">@c.DriverName</p>
                                <p class="text-xs text-muted">🚗 @c.DriverPlaca</p>
                            </div>
                        </div>
                        <BadgeCarga Status="@c.Status" />
                    </div>

                    <div class="carga-card-meta">
                        <span class="text-xs text-muted">📍 @c.Distrito</span>
                        <span class="text-xs text-muted">
                            📅 @c.FechaCreacion.ToLocalTime().ToString("dd/MM HH:mm")
                        </span>
                    </div>

                    <!-- Barra de progreso -->
                    <div class="carga-progress-bar">
                        <div class="carga-progress-fill"
                             style="width: @(c.TotalPedidos > 0 ? (c.Entregados + c.EnOnStorage) * 100 / c.TotalPedidos : 0)%">
                        </div>
                    </div>

                    <div class="carga-card-stats">
                        <span class="text-xs" style="color:var(--estado-encamino)">
                            ⏳ @c.Pendientes pendientes
                        </span>
                        <span class="text-xs" style="color:var(--estado-entregado)">
                            ✅ @c.Entregados entregados
                        </span>
                        <span class="text-xs" style="color:var(--estado-almacen)">
                            🏭 @c.EnOnStorage en almacén
                        </span>
                    </div>

                    @if (c.Status == CargaStatus.Concluida)
                    {
                        <button class="btn btn-success btn-sm w-full mt-4"
                                @onclick:stopPropagation
                                @onclick="() => FacturarAsync(c.Id)">
                            💰 Facturar carga
                        </button>
                    }
                </div>
            }
        </div>
    }
}

<!-- Modal detalle -->
<GenericModal Title="Detalle de carga"
              IsVisible="_mostrarDetalle"
              OnCancel="() => _mostrarDetalle = false"
              Size="lg">
    <BodyContent>
        @if (_cargaDetalle is not null)
        {
            <div class="adm-modal__body">
                <CargaDetailPanel Carga="_cargaDetalle" />
            </div>
            <div class="adm-modal__footer">
                <button class="btn btn-ghost btn-sm"
                        @onclick="() => _mostrarDetalle = false">
                    Cerrar
                </button>
            </div>
        }
    </BodyContent>
</GenericModal>


@code {
    private List<CargaSummaryDTO>? _cargas;
    private CargaDetailDTO? _cargaDetalle;
    private bool _loading = true;
    private bool _mostrarDetalle;
    private CargaStatus? _tabActivo = null;

    private record TabItem(string Icono, string Label, CargaStatus? Status, int Count);
    private List<TabItem> _tabs = [];

    private IEnumerable<CargaSummaryDTO> CargasFiltradas =>
        _tabActivo is null
            ? _cargas ?? []
            : (_cargas ?? []).Where(c => c.Status == _tabActivo);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _NotificationService.OnDashboardUpdate += Recargar;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        var r = await _Repository.GetAsync<List<CargaSummaryDTO>>("api/Cargas/GetAll");
        if (!r.Error) _cargas = r.Response;
        BuildTabs();
        _loading = false;
    }

    private void BuildTabs()
    {
        _tabs =
        [
            new("📋", "Todas",      null,                         _cargas?.Count ?? 0),
            new("🟢", "Activas",    CargaStatus.Activa,           _cargas?.Count(c => c.Status == CargaStatus.Activa) ?? 0),
            new("⏳", "Pendientes", CargaStatus.PendienteConclusion, _cargas?.Count(c => c.Status == CargaStatus.PendienteConclusion) ?? 0),
            new("✅", "Concluidas", CargaStatus.Concluida,        _cargas?.Count(c => c.Status == CargaStatus.Concluida) ?? 0),
            new("💰", "Facturadas", CargaStatus.Facturada,        _cargas?.Count(c => c.Status == CargaStatus.Facturada) ?? 0),
        ];
    }

    private async Task AbrirDetalle(int id)
    {
        var r = await _Repository.GetAsync<CargaDetailDTO>($"api/Cargas/Detail/{id}");
        if (!r.Error)
        {
            _cargaDetalle  = r.Response;
            _mostrarDetalle = true;
        }
    }

    private async Task FacturarAsync(int id)
    {
        var r = await _Repository.PostAsync<CargaFacturarDTO>(
            $"api/Cargas/Facturar/{id}", new CargaFacturarDTO());
        if (!r.Error) await LoadAsync();
    }

    private void CambiarTab(CargaStatus? status)
    {
        _tabActivo = status;
        StateHasChanged();
    }

    private void Recargar() => InvokeAsync(async () =>
    {
        await LoadAsync();
        StateHasChanged();
    });

    private static string Initials(string name)
    {
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}"
            : name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }

    public void Dispose()
    {
        _NotificationService.OnDashboardUpdate -= Recargar;
    }
}