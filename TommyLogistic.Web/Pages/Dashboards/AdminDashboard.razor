
@page "/AdminDashboard"
@layout MainLayout
@inject IJSRuntime _IJSRuntime
@inject HttpClient _HttpClient
@inject SweetAlertService _Swal
@inject OrderService _OrderService
@inject NavigationManager _NavigationManager
@attribute [Authorize(Roles = nameof(UserEnum.Admin))]

<PageTitle>Dashboard — Tommy Logistic</PageTitle>

@if (_loading)
{
    <div class="loading-overlay">
        <div class="spinner"></div>
        <span>Cargando dashboard...</span>
    </div>
}
else
{
    <div class="dashboard-header">
        <h1 class="page-title">Dashboard</h1>
        <div class="dashboard-actions">
            <button class="btn btn-ghost" @onclick="SimularRecepcionMasiva">
                📥 Simular comandas
            </button>
            <button class="btn btn-success" @onclick="ExecuteAutoAssign">
                ⚡ Armar cargas
            </button>
            <button class="btn btn-outline" @onclick="@(() => _NavigationManager.NavigateTo("/Orders"))">
                📦 Ver pedidos
            </button>
        </div>
    </div>

    <div class="dashboard-grid">
        <div class="stat-card-v2" style="--sc-color:#1a56db; --sc-bg:#e8f0fe">
            <div class="stat-card-v2__icon">📦</div>
            <div class="stat-card-v2__body">
                <span class="stat-card-v2__label">Pedidos hoy</span>
                <span class="stat-card-v2__value">@Data.TotalToday</span>
            </div>
        </div>

        <div class="stat-card-v2" style="--sc-color:#0e9f6e; --sc-bg:#def7ec">
            <div class="stat-card-v2__icon">✅</div>
            <div class="stat-card-v2__body">
                <span class="stat-card-v2__label">Entregados</span>
                <span class="stat-card-v2__value">@Data.Delivered</span>
            </div>
        </div>

        <div class="stat-card-v2" style="--sc-color:#7c3aed; --sc-bg:#f3e8ff">
            <div class="stat-card-v2__icon">🚚</div>
            <div class="stat-card-v2__body">
                <span class="stat-card-v2__label">En camino</span>
                <span class="stat-card-v2__value">@Data.OnTheWay</span>
            </div>
        </div>

        <div class="stat-card-v2" style="--sc-color:#6366f1; --sc-bg:#eef2ff">
            <div class="stat-card-v2__icon">🏭</div>
            <div class="stat-card-v2__body">
                <span class="stat-card-v2__label">En almacén</span>
                <span class="stat-card-v2__value">@Data.OnStorage</span>
            </div>
        </div>

        <div class="stat-card-v2" style="--sc-color:#d97706; --sc-bg:#fef3c7">
            <div class="stat-card-v2__icon">🔄</div>
            <div class="stat-card-v2__body">
                <span class="stat-card-v2__label">Reprogramados</span>
                <span class="stat-card-v2__value">@Data.Rescheduled</span>
            </div>
        </div>

        <div class="stat-card-v2" style="--sc-color:#e02424; --sc-bg:#fde8e8">
            <div class="stat-card-v2__icon">❌</div>
            <div class="stat-card-v2__body">
                <span class="stat-card-v2__label">Fallidos</span>
                <span class="stat-card-v2__value">@Data.Failed</span>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="movimientos-header">
            <h2 class="card-title">Movimientos en tiempo real</h2>
            <span class="live-dot">EN VIVO</span>
        </div>

        @if (!UltimosMovimientos.Any())
        {
            <div class="empty-state">
                <span class="empty-icon">📡</span>
                <p class="text-bold">Sin movimientos aún</p>
                <p class="text-muted">Los eventos aparecerán aquí en tiempo real</p>
            </div>
        }
        else
        {
            <div class="table-wrapper">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Destinatario</th>
                            <th class="hide-mobile">Distrito</th>
                            <th>Estado</th>
                            <th class="hide-mobile">Repartidor</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in UltimosMovimientos)
                        {
                            <tr @onclick="@(() => _NavigationManager.NavigateTo($"/pedidos/{p.Id}"))">
                                <td>
                                    <span class="codigo-seguimiento">@p.TrackingCode</span>
                                </td>
                                <td class="text-bold">@p.RecipientName</td>
                                <td class="hide-mobile text-muted">@p.RecipientDistrict</td>
                                <td><BadgeEstado Estado="@p.OrderStatus" /></td>
                                <td class="hide-mobile text-muted">@(p.DeliveryPersonName ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@code {
    private bool _loading = true;
    public DashboardAdminDTO Data { get; set; } = null!;
    public List<OrderSummaryDTO> UltimosMovimientos { get; set; } = [];

    protected override void OnInitialized()
    {
        Data ??= new DashboardAdminDTO();
        _loading = false;
    }

    private async Task SimularRecepcionMasiva()
    {
        Random random = new();
        List<ExternalOrderDTO> listaPedidos = [];
        string[] empresas = { "naruto@yopmail.com", "angelina@yopmail.com" };
        string[] productos = { "Caja de Herramientas", "Monitor 24p", "Zapatillas Running", "Kit de Limpieza", "Teclado Mecánico", "Cafetera Express" };
        string[] nombres = { "Monkey D. Luffy", "Roronoa Zoro", "Nami Swan", "Sanji Vinsmoke", "Tony Chopper", "Nico Robin" };
        string[] distritos = { "Miraflores", "San Isidro", "Surco", "Los Olivos", "Lince" };

        for (int i = 1; i <= 30; i++)
        {
            listaPedidos.Add(new ExternalOrderDTO
            {
                CompanyEmail = empresas[random.Next(empresas.Length)],
                ProductName = $"{productos[random.Next(productos.Length)]} #{i}",
                Quantity = random.Next(1, 5),
                Recipient = nombres[random.Next(nombres.Length)],
                Address = $"Calle Ficticia {random.Next(100, 999)}",
                District = distritos[random.Next(distritos.Length)],
                Phone = $"9{random.Next(10000000, 99999999)}"
            });
        }

        var response = await _OrderService.SimularRecepcionMasiva(listaPedidos);

        if (!response)
        {
            await _Swal.FireAsync("Atención", "Algo salió mal con la simulación", SweetAlertIcon.Warning);
            return;
        }

        await _Swal.FireAsync(new SweetAlertOptions
        {
            Title = "¡Simulación completada!",
            Text = "Se crearon 30 pedidos de prueba 👍🏽",
            Icon = SweetAlertIcon.Success,
            ConfirmButtonText = "Entendido"
        });
    }

    private async Task ExecuteAutoAssign()
    {
        var response = await _HttpClient.PostAsync("api/Orders/AutoRouteAndAssign", null);

        if (!response.IsSuccessStatusCode)
        {
            var errorContent = await response.Content.ReadAsStringAsync();
            await _Swal.FireAsync("Atención", errorContent, SweetAlertIcon.Warning);
            return;
        }

        var datos = await response.Content.ReadFromJsonAsync<AssignmentResponse>();

        if (datos != null)
        {
            await _Swal.FireAsync(new SweetAlertOptions
            {
                Title = "¡Asignación exitosa!",
                Text = $"{datos.Message} — Conductores usados: {datos.DriversUsed}",
                Icon = SweetAlertIcon.Success,
                ConfirmButtonText = "Entendido"
            });
        }
    }

    public class AssignmentResponse
    {
        public string Message { get; set; } = "";
        public int DriversUsed { get; set; }
        public int OrdersPending { get; set; }
    }
}
