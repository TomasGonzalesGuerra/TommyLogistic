@page "/ClientDashboard"
@layout MainLayout
@inject IRepository _IRepository
@inject NavigationManager _NavigationManager
@inject NotificationService _NotificationService
@attribute [Authorize(Roles = nameof(UserEnum.Client))]

<PageTitle>Dashboard Cliente</PageTitle>

@if (loading)
{
    <div class="loading-state">
        <div class="spinner"></div>
        <p>Cargando tus pedidos...</p>
    </div>
}
else
{
    <!-- Stats Cards -->
    <section class="stats-grid" style="grid-template-columns: repeat(4, 1fr);">
        <div class="stat-card">
            <div class="stat-icon" style="background: var(--color-primary-light);">📦</div>
            <div class="stat-info">
                <span class="stat-value">Total</span>
                <span class="stat-label">Total Pedidos</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: #e8f5e9;">🚚</div>
            <div class="stat-info">
                <span class="stat-value">EnTransito</span>
                <span class="stat-label">En Tránsito</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: #e3f2fd;">✅</div>
            <div class="stat-info">
                <span class="stat-value">Entregados</span>
                <span class="stat-label">Entregados</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: #fff3e0;">⏳</div>
            <div class="stat-info">
                <span class="stat-value">Pendientes</span>
                <span class="stat-label">Pendientes</span>
            </div>
        </div>
    </section>

    <!-- Pedidos Activos -->
    <section class="section-card">
        <div class="section-header">
            <h2>Pedidos Activos</h2>
            <a href="/client/pedidos" class="btn btn-ghost btn-sm">Ver todos →</a>
        </div>

        @if (!pedidosActivos.Any())
        {
            <div class="empty-state">
                <span class="empty-icon">📭</span>
                <p>No tienes pedidos activos en este momento</p>
                <a href="/client/pedidos/nuevo" class="btn btn-primary">Crear Pedido</a>
            </div>
        }
        else
        {
            <div class="orders-list">
                @foreach (var order in pedidosActivos)
                {
                    <div class="order-card-client" @onclick="() => VerDetalle(order.Id)">
                        <div class="order-card-header">
                            <div class="order-id">#@order.Id.ToString().Substring(0, 8).ToUpper()</div>
                        </div>
                        <div class="order-card-body">
                            <div class="order-route">
                                <span class="route-point origin">📍 @order.RecipientName</span>
                                <span class="route-arrow">→</span>
                                <span class="route-point dest">🎯 @order.RecipientDistrict</span>
                            </div>
                            @if (true)
                            {
                                <div class="order-driver">
                                    <span class="driver-avatar">🧑‍✈️</span>
                                    <span class="driver-name">FullName</span>
                                </div>
                            }
                        </div>
                        <div class="order-card-footer">
                            <span class="order-date">@order.RegistrationDate.ToString("dd/MM/yyyy")</span>
                            <span class="order-items"> paquetes</span>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <!-- Historial reciente -->
    <section class="section-card">
        <div class="section-header">
            <h2>Historial Reciente</h2>
        </div>
        <div class="history-list">
            @* @foreach (var order in historial.Take(5)) *@
            @if (true)
            {
                <div class="history-item">
                    <div class="history-status-dot @GetStatusClass("Delivered")"></div>
                    <div class="history-info">
                        <span class="history-id">#.Id.ToString().Substring(0, 8).ToUpper()</span>
                        <span class="history-route">OriginDistrict → .DestinationDistrict</span>
                    </div>
                    <div class="history-meta">
                        <span class="history-date">UpdatedAt?.ToString("dd/MM")</span>
                    </div>
                </div>
            }
        </div>
    </section>
}

@code {
    private bool loading = true;
    private ClientDashboard stats = new();
    private List<OrderSummaryDTO> pedidosActivos = new();
    private List<OrderSummaryDTO> historial = new();

    protected override async Task OnInitializedAsync()
    {
        // Suscribir a updates en tiempo real
        _NotificationService.OnDashboardUpdate += HandleDashboardUpdate;

        await LoadDashboard();
    }

    private async Task LoadDashboard()
    {
        loading = true;
        // var response = await _IRepository.GetAsync<ClientDashboardDTO>("api/orders/client-dashboard");
        // if (response.IsSuccess && response.Result != null)
        // {
        //     stats = response.Result.Stats;
        //     pedidosActivos = response.Result.Activos;
        //     historial = response.Result.Historial;
        // }
        Task.Delay(2500).Wait();
        loading = false;
    }

    private async void HandleDashboardUpdate()
    {
        await LoadDashboard();
        await InvokeAsync(StateHasChanged);
    }

    private void VerDetalle(int orderId) =>
        _NavigationManager.NavigateTo($"/pedidos/{orderId}");

    private string GetStatusClass(string status) => status switch
    {
        "Delivered" => "status-dot--delivered",
        "OnTheWay" => "status-dot--transit",
        "Failed" => "status-dot--failed",
        _ => "status-dot--default"
    };

    public void Dispose()
    {
        _NotificationService.OnDashboardUpdate -= HandleDashboardUpdate;
    }
}