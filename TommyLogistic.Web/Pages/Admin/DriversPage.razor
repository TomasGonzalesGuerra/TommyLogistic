@page "/Drivers"
@layout MainLayout
@inject DriverService _DriverService
@attribute [Authorize(Roles = "Admin")]
@inject NavigationManager _NavigationManager

<PageTitle>Repartidores — Tommy Logistic</PageTitle>

<div class="list-header">
    <h1 class="page-title">Repartidores</h1>
    <button @onclick="OpenModal" class="btn btn-primary">➕ Nuevo repartidor</button>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger mb-4">
        <span>⚠️</span><span>@_error</span>
    </div>
}

@if (_loading)
{
    <div class="loading-overlay"><div class="spinner"></div></div>
}
else
{
    <div class="repartidores-grid">
        @foreach (var item in _allDriversDTO)
        {
            <div class="rep-card">
                <div class="rep-card-header">
                    <div class="rep-avatar" style="background: @(item.Available ? "var(--color-success)" : "var(--color-text-muted)")">
                        <img src="@item.Photo" alt="@item.FullName" />
                    </div>

                    <div class="rep-info">
                        <span class="rep-nombre">@item.FullName</span>
                        <span class="text-xs text-muted">DNI: @item.DNI</span>
                    </div>

                    <span class="badge @(item.Available ? "badge-entregado" : "badge-registrado")">
                        @(item.Available ? "Disponible" : "Ocupado")
                    </span>
                </div>

                <div class="rep-meta">
                    <span class="text-sm">🚗 @item.Placa</span>
                    <span class="text-sm">📞 @item.Celular</span>
                    @if (item.Available)
                    {
                        <span class="badge badge-ausente">Sin acceso al sistema</span>
                    }
                </div>

                <div class="rep-stats">
                    <div class="rep-stat-mini">
                        <span style="color: var(--color-primary)">
                            @item.ActiveOrderToday
                        </span>
                        <span class="text-xs text-muted">Activos</span>
                    </div>
                    <div class="rep-stat-mini">
                        <span style="color: var(--color-success)">
                            @item.DeliveredToday
                        </span>
                        <span class="text-xs text-muted">Entregados</span>
                    </div>
                </div>

                <div class="rep-acciones">
                    <button class="btn btn-ghost btn-sm"
                            @onclick="@(() => _NavigationManager.NavigateTo($"/pedidos/repartidor/{item.Id}"))">
                        Ver pedidos
                    </button>
                    <button class="btn btn-ghost btn-sm">
                        @(item.Available ? "Marcar ocupado" : "Marcar libre")
                    </button>
                </div>
            </div>
        }
    </div>
}

<GenericModal TModel="DriverCreatedDTO"
              Model="_CreatedDTO"
              Title="Nuevo Repartidor"
              IsVisible="_mostrarForm"
              OnConfirm="OnConfirm"
              OnCancel="OnCancel">
    <BodyContent>
        <DriverForm _DTO="_CreatedDTO" />
    </BodyContent>
</GenericModal>


@code {
    private List<DriverDTO> _allDriversDTO = [];
    private DriverCreatedDTO _CreatedDTO = new();
    private bool _loading = true;
    private bool _mostrarForm;
    private bool _guardando;
    private string? _error;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _allDriversDTO = await _DriverService.GetAllDriversAsync();
        _loading = false;
    }

    private void OpenModal() => _mostrarForm = true;

    private async Task OnCancel()
    {
        _mostrarForm = false;
        _CreatedDTO = new();
    }

    private async Task OnConfirm()
    {
        _mostrarForm = false;
        _CreatedDTO = new();
    }
}
