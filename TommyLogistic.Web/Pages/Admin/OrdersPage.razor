@page "/Orders"
@layout MainLayout
@inject OrderService _OrderService
@attribute [Authorize(Roles = $"{nameof(UserEnum.Admin)}, {nameof(UserEnum.Supervisor)}")]

<PageTitle>Pedidos — Logistic</PageTitle>

<div class="list-header">
    <h1 class="page-title">Todos los pedidos</h1>

    <button class="btn btn-primary">
        ➕ Nuevo pedido
    </button>
</div>

<div class="filtros-bar">
    <div class="filtro-search">
        <input @bind="_busqueda" @bind:event="oninput" class="form-control" type="search" placeholder="Buscar código, destinatario, distrito..." />
    </div>

    <div class="filtro-estado">
        <select class="form-control" @bind="_filtroEstado">
            <option value="">Todos los estados</option>
            @foreach (var e in Enum.GetValues<OrderStatus>())
            {
                <option value="@((int)e)">@NombreEstado(e)</option>
            }
        </select>
    </div>

    <div class="filtro-tipo">
        <select @bind="_filtroTipo" class="form-control">
            <option value="">Todos los tipos</option>
            <option value="1">Mismo día</option>
            <option value="2">Día siguiente</option>
        </select>
    </div>
    <button @onclick="Refrescar" class="btn btn-ghost btn-sm" title="Actualizar">
        🔄
    </button>
</div>

@if (_loading)
{
    <div class="loading-overlay">
        <div class="spinner"></div>
        <span>Cargando pedidos...</span>
    </div>
}
else if (!PedidosFiltrados.Any())
{
    <div class="empty-state">
        <div class="empty-icon">📭</div>
        <p class="text-bold">No hay pedidos</p>
        <p class="text-muted">
            @(_busqueda.Length > 0 || _filtroEstado.Length > 0 ? "Prueba con otros filtros" : "Aún no hay pedidos registrados")
        </p>
    </div>
}
else
{
    <div class="list-summary text-muted text-sm mb-4">
        @PedidosFiltrados.Count() pedidos
    </div>

    <div class="empty-state">
        <div class="empty-icon">📭</div>
        <p class="text-bold">
            @($"Tenemos {PedidosFiltrados.Count()} Pedidos Registrados")
        </p>
    </div>
}


@if (_loading)
{
    <div class="loading-overlay">
        <div class="spinner"></div>
        <span>Cargando pedidos...</span>
    </div>
}
else if (_cargas is null || _cargas.Count() == 0)
{
    <div class="empty-state">
        <div class="empty-icon">😭</div>
        <p class="text-bold">
            @("No hay cargas activas en este Momento")
        </p>
    </div>        
}
else
{
    <!-- Vista tarjetas -->
    <div class="pedido-cards">
        @foreach (var item in _cargas)
        {
            <div class="pedido-card @(_newsIds.Contains(item.Id) ? "pedido-card--nuevo" : "")"
                    @onclick="() => ShowPreview(item.Id)">

                <div class="pedido-card-top">
                    <span class="codigo-seguimiento">@item.Id</span>
                    <span class="codigo-badge">@item.Status</span>
                </div>

                <div class="pedido-card-nombre">@item.DriverName</div>

                <div class="pedido-card-meta">
                    <span>📱 @item.DriverPlaca</span>
                    <span>📍 @item.Distrito</span>
                    <span>📱 @item.TotalPedidos</span>
                </div>
            </div>
        }
    </div>    
}


<GenericModal Title="Detalle del pedido"
              IsVisible="_mostrarPreview"
              OnCancel="CerrarPreview"
              Size="lg">
    <BodyContent>
        <OrderDetailsPreview OrderId="_pedidoSeleccionadoId" OnClose="CerrarPreview" />
    </BodyContent>
</GenericModal>


@code {
    private int _nuevos;
    private bool _loading = true;
    private HashSet<int> _newsIds = [];
    private string _busqueda = string.Empty;
    private string _filtroTipo = string.Empty;
    private List<OrderSummaryDTO> _orders = [];
    private List<CargaSummaryDTO> _cargas = [];
    private string _filtroEstado = string.Empty;
    private IEnumerable<OrderSummaryDTO> PedidosFiltrados =>
        _orders.Where(p =>
        {
            var matchBusqueda = string.IsNullOrWhiteSpace(_busqueda) ||
                p.TrackingCode!.Contains(_busqueda, StringComparison.OrdinalIgnoreCase) ||
                p.RecipientName!.Contains(_busqueda, StringComparison.OrdinalIgnoreCase) ||
                p.RecipientDistrict!.Contains(_busqueda, StringComparison.OrdinalIgnoreCase);

            var matchEstado = string.IsNullOrWhiteSpace(_filtroEstado) ||
                (int)p.OrderStatus == int.Parse(_filtroEstado);

            var matchTipo = string.IsNullOrWhiteSpace(_filtroTipo) ||
                (int)p.DeliveryType == int.Parse(_filtroTipo);

            return matchBusqueda && matchEstado && matchTipo;
        });
    private bool _mostrarPreview;
    private int _pedidoSeleccionadoId;


    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        try
        {
            _cargas = await _OrderService.GetAllCargasAsync();
            _orders = await _OrderService.GetAllOrdersAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task Refrescar()
    {
        _nuevos = 0;
        _newsIds.Clear();
        await LoadAsync();
    }

    private void ShowPreview(int ID)
    {
        _pedidoSeleccionadoId = ID;
        _mostrarPreview = true;
    }

    private async Task CerrarPreview()
    {
        _pedidoSeleccionadoId = 0;
        _mostrarPreview = false;
    }

    private static string NombreEstado(OrderStatus e) => e switch
    {
        OrderStatus.Failed => "Fallido",
        OrderStatus.PickedUp => "Retirado",
        OrderStatus.Assigned => "Asignado",
        OrderStatus.OnTheWay => "En camino",
        OrderStatus.Delivered => "Entregado",
        OrderStatus.Returning => "En retorno",
        OrderStatus.OnStorage => "En almacén",
        OrderStatus.Registered => "Registrado",
        OrderStatus.Rescheduled => "Reprogramado",
        OrderStatus.RecipientAbsent => "Destinatario Ausente",
        _ => e.ToString()
    };
}
