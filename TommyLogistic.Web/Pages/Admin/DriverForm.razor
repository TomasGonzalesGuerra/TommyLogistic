<div class="form-row">
    <div class="form-group">
        <label class="form-label required">Nombre</label>
        <input class="form-control" @bind="_DTO.FullName" />
    </div>
</div>

<div class="form-row">
    <div class="form-group">
        <label class="form-label required">DNI</label>
        <input class="form-control" @bind="_DTO.DNI" />
    </div>

    <div class="form-group">
        <label class="form-label required">Teléfono</label>
        <input class="form-control" @bind="_DTO.Celular" />
    </div>
</div>

<div class="form-group">
    <label class="form-label required">Placa del vehículo</label>
    <input class="form-control" @bind="_DTO.Placa" />
</div>


@code {
    [Parameter , EditorRequired]
    public DriverCreatedDTO _DTO { get; set; }
}
