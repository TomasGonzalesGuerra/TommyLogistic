@page "/MyCargasPage"
@layout MainLayout
@inject DriverService _DriverService
@attribute [Authorize(Roles = nameof(UserEnum.Driver))]

<PageTitle>Mis Cargas — Tommy Logistic</PageTitle>

<!-- ── BARRA DE BÚSQUEDA (siempre visible) ── -->
<div class="search-bar">
    <div class="search-bar-inner">
        <div class="filtro-group">
            <label class="form-label">Fecha</label>
            <input type="date"
                   class="form-control form-control-sm search-date-input"
                   @bind="_fechaTemp"
                   max="@DateTime.Today.ToString("yyyy-MM-dd")" />
        </div>

        <div class="search-actions">
            <button class="btn btn-primary" disabled="@(_fechaTemp is null || _loading)" @onclick="EjecutarBusqueda">
                🔍 Buscar
            </button>

            @if (_fechaBusqueda is not null)
            {
                <button class="btn btn-ghost" @onclick="LimpiarBusqueda">
                    🧹 Limpiar
                </button>
            }
        </div>

        @if (_response is not null && _response.Items.Any())
        {
            <div class="results-header">
                <div class="results-header-left">
                    <span class="results-date">
                        📅 @_fechaBusqueda!.Value.ToString("dddd dd \\d\\e MMMM yyyy", new System.Globalization.CultureInfo("es-PE"))
                    </span>
                </div>
            </div>

            <div class="results-butons-header">
                @foreach (CargaStatus item in Enum.GetValues(typeof(CargaStatus)))
                {
                    <button class="btn btn-ghost" @onclick="LimpiarBusqueda">
                        @item.ToString()
                    </button>
                }
            </div>
        }
    </div>
</div>

<!-- ── ESTADO IDLE ── -->
@if (_fechaBusqueda is null)
{
    <div class="idle-state">
        <div class="idle-icon">📦</div>
        <h2 class="idle-title">Consulta tus cargas</h2>
        <p class="idle-subtitle">Selecciona una fecha para ver todas las cargas asignadas ese día.</p>
    </div>
}
else if (_loading)
{
    <div class="loading-overlay">
        <div class="spinner"></div>
        <span>Buscando cargas para @_fechaBusqueda.Value.ToString("dd/MM/yyyy")…</span>
    </div>
}
else if (_response is null || !_response.Items.Any())
{
    <div class="empty-state">
        <span class="empty-icon">📭</span>
        <p class="text-bold">Sin cargas para el @_fechaBusqueda.Value.ToString("dd/MM/yyyy")</p>
        <p class="text-muted">No se encontraron cargas con los filtros seleccionados.</p>
    </div>
}
else
{
    <div class="miscargas-list">
        @foreach (var carga in _response.Items)
        {
            var pct = carga.TotalPedidos > 0 ? (int)Math.Round(carga.Entregados * 100.0 / carga.TotalPedidos) : 0;
            <details class="carga-detail-card @($"carga--{carga.Status}")" open="@(_expandedId == carga.Id)">
                <summary class="carga-detail-summary" @onclick="() => ToggleExpand(carga.Id)" @onclick:preventDefault="true">
                    <div class="carga-detail-chevron">
                        @(_expandedId == carga.Id ? "▾" : "▸")
                    </div>

                    <div class="carga-detail-header-info">
                        <div class="carga-detail-title">
                            <span class="font-bold">Carga #@carga.Id</span>
                            <BadgeCarga Status="@carga.Status" />
                        </div>
                        <div class="carga-detail-meta">
                            <span>🕐 @carga.FechaCreacion.ToString("HH:mm")</span>
                            <span>👤 @carga.SupervisorName</span>
                            @if (carga.FechaConcluida.HasValue)
                            {
                                <span>✅ Concluida @carga.FechaConcluida.Value.ToString("HH:mm")</span>
                            }
                        </div>
                    </div>

                    <!-- Mini stats -->
                    <div class="carga-detail-mini-stats">
                        <span class="mini-stat" title="Total pedidos">📦 @carga.TotalPedidos</span>
                        <span class="mini-stat mini-stat--success" title="Entregados">✅ @carga.Entregados</span>
                        @if (carga.Fallidos > 0)
                        {
                            <span class="mini-stat mini-stat--danger" title="Fallidos">❌ @carga.Fallidos</span>
                        }
                        @if (carga.Ausentes > 0)
                        {
                            <span class="mini-stat mini-stat--warning" title="Ausentes">🚪 @carga.Ausentes</span>
                        }
                        @if (carga.EnRetorno > 0)
                        {
                            <span class="mini-stat mini-stat--info" title="En retorno">↩️ @carga.EnRetorno</span>
                        }
                    </div>
                </summary>

                <!-- Barra de progreso (fuera del summary, siempre visible) -->
                <div class="carga-progress-wrap">
                    <div class="carga-progress-bar">
                        <div class="carga-progress-fill @($"carga-progress--{carga.Status}")"
                             style="width: @pct%"></div>
                    </div>
                    <span class="carga-progress-label">
                        @carga.Entregados de @carga.TotalPedidos entregados · @pct%
                    </span>
                </div>

                <!-- ── CUERPO EXPANDIDO ── -->
                <div class="carga-detail-body">
                    <div class="carga-info-grid">
                        <div class="carga-info-item">
                            <span class="carga-info-label">Estado</span>
                            <BadgeCarga Status="@carga.Status" />
                        </div>
                        <div class="carga-info-item">
                            <span class="carga-info-label">Creada</span>
                            <span>@carga.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                        <div class="carga-info-item">
                            <span class="carga-info-label">Supervisor</span>
                            <span>@carga.SupervisorName</span>
                        </div>
                        @if (carga.FechaConcluida.HasValue)
                        {
                            <div class="carga-info-item">
                                <span class="carga-info-label">Concluida</span>
                                <span>@carga.FechaConcluida.Value.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                        }
                        @if (carga.ConcluidaPorName is not null)
                        {
                            <div class="carga-info-item">
                                <span class="carga-info-label">Concluida por</span>
                                <span>@carga.ConcluidaPorName</span>
                            </div>
                        }
                        @if (carga.FechaFacturada.HasValue)
                        {
                            <div class="carga-info-item">
                                <span class="carga-info-label">Facturada</span>
                                <span>@carga.FechaFacturada.Value.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                        }
                        @if (carga.FacturadaPorName is not null)
                        {
                            <div class="carga-info-item">
                                <span class="carga-info-label">Facturada por</span>
                                <span>@carga.FacturadaPorName</span>
                            </div>
                        }
                        @if (carga.NotaConclusion is not null)
                        {
                            <div class="carga-info-item carga-info-item--full">
                                <span class="carga-info-label">Nota conclusión</span>
                                <span>@carga.NotaConclusion</span>
                            </div>
                        }
                        @if (carga.NotaFacturacion is not null)
                        {
                            <div class="carga-info-item carga-info-item--full">
                                <span class="carga-info-label">Nota facturación</span>
                                <span>@carga.NotaFacturacion</span>
                            </div>
                        }
                    </div>

                    <!-- Pedidos -->
                    @if (carga.Pedidos.Any())
                    {
                        <h5 class="carga-section-title">📦 Pedidos (@carga.Pedidos.Count)</h5>

                        <div class="driver-orders-list">
                            @foreach (var pedido in carga.Pedidos)
                            {
                                <div class="driver-order-card entrega-card">
                                    <div class="driver-order-top">
                                        <span class="codigo-seguimiento">@pedido.TrackingCode</span>
                                        <BadgeEstado Estado="@pedido.OrderStatus" />
                                    </div>

                                    <div class="driver-order-nombre">@pedido.RecipientName</div>

                                    <div class="driver-order-meta">
                                        <span>📍 @pedido.RecipientAddress, @pedido.RecipientDistrict</span>
                                        <span>📞 @pedido.RecipientPhone</span>
                                        <span>📦 @pedido.PackageDescription (@pedido.Quantity u.)</span>
                                        <span>🏢 @pedido.CompanyName</span>
                                        <span>🚚 @(pedido.DeliveryType == DeliveryType.ToDay ? "Mismo día" : "Al día siguiente")</span>
                                        @if (pedido.DeliveryDate.HasValue)
                                        {
                                            <span>✅ Entregado: @pedido.DeliveryDate.Value.ToString("HH:mm")</span>
                                        }
                                        @if (pedido.RescheduledDate.HasValue)
                                        {
                                            <span>🔄 Reprogramado: @pedido.RescheduledDate.Value.ToString("dd/MM/yyyy")</span>
                                        }
                                    </div>

                                    @if (pedido.DeliveryAttempts > 0)
                                    {
                                        <p class="pedido-card-intentos">⚠️ @pedido.DeliveryAttempts intento(s) fallido(s)</p>
                                    }

                                    @if (pedido.Events.Any())
                                    {
                                        <div class="pedido-timeline">
                                            <p class="pedido-timeline-title">🕐 Historial</p>
                                            @foreach (var ev in pedido.Events)
                                            {
                                                <div class="timeline-event">
                                                    <div class="timeline-dot"></div>
                                                    <div class="timeline-content">
                                                        <div class="timeline-header">
                                                            <BadgeEstado Estado="@ev.NewStatus" />
                                                            <span class="text-muted text-xs">
                                                                @ev.Timestamp.ToString("dd/MM HH:mm") · @ev.UserName
                                                            </span>
                                                        </div>
                                                        @if (ev.Note is not null)
                                                        {
                                                            <p class="timeline-nota">📝 @ev.Note</p>
                                                        }
                                                        @if (ev.BaglokLocation is not null)
                                                        {
                                                            <p class="timeline-nota">📍 @ev.BaglokLocation</p>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </details>
        }
    </div>

    <!-- Paginación -->
    @if (_response.TotalPages > 1)
    {
        <div class="entregas-paginacion">
            <button class="btn btn-ghost btn-sm"
                    disabled="@(_page <= 1 || _loading)"
                    @onclick="() => CambiarPagina(_page - 1)">
                ← Anterior
            </button>

            @for (int i = 1; i <= _response.TotalPages; i++)
            {
                var pageNum = i;
                <button class="btn btn-sm @(pageNum == _page ? "btn-primary" : "btn-ghost")"
                        disabled="@_loading"
                        @onclick="() => CambiarPagina(pageNum)">
                    @pageNum
                </button>
            }

            <button class="btn btn-ghost btn-sm"
                    disabled="@(_page >= _response.TotalPages || _loading)"
                    @onclick="() => CambiarPagina(_page + 1)">
                Siguiente →
            </button>
        </div>
    }

    <p class="entregas-info-pagina text-muted text-xs">
        Mostrando @((_page - 1) * _pageSize + 1)–@(Math.Min(_page * _pageSize, _response.TotalItems))
        de @_response.TotalItems carga(s)
    </p>
}

@code {
    private MyCargasResponseDTO? _response;
    private bool _loading;
    private int _page = 1;
    private int _pageSize = 8;
    private DateTime? _fechaTemp;
    private string _statusTemp = "";
    private DateTime? _fechaBusqueda;
    private CargaStatus? _statusFiltro;
    private int? _expandedId;


    private async Task LoadAsync()
    {
        if (_fechaBusqueda is null) return;

        _loading = true;
        StateHasChanged();

        _response = await _DriverService.GetMyCargasAsync(
            _page, _pageSize,
            desde: _fechaBusqueda.Value.Date,
            hasta: _fechaBusqueda.Value.Date.AddDays(1).AddSeconds(-1));

        _loading = false;
    }

    private async Task EjecutarBusqueda()
    {
        if (_fechaTemp is null) return;

        _page = 1;
        _expandedId = null;
        _fechaBusqueda = _fechaTemp;
        _statusFiltro = string.IsNullOrEmpty(_statusTemp)
            ? null
            : Enum.Parse<CargaStatus>(_statusTemp);

        await LoadAsync();
    }

    private void ToggleExpand(int id) => _expandedId = _expandedId == id ? null : id;

    private async Task CambiarPagina(int nuevaPagina)
    {
        _page = nuevaPagina;
        _expandedId = null;
        await LoadAsync();
    }

    private Task LimpiarBusqueda()
    {
        _page = 1;
        _expandedId = null;
        _fechaTemp = null;
        _statusTemp = "";
        _fechaBusqueda = null;
        _statusFiltro = null;
        _response = null;
        return Task.CompletedTask;
    }
}
