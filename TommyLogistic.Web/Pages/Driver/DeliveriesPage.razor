@page "/DeliveriesPage"
@layout MainLayout
@inject DriverService _DriverService
@attribute [Authorize(Roles = nameof(UserEnum.Driver))]

<PageTitle>Mis Entregas — Tommy Logistic</PageTitle>

<!-- ── BARRA DE BÚSQUEDA ── -->
<div class="search-bar">
    <div class="search-bar-inner">
        <div class="filtro-group">
            <label class="form-label">Fecha</label>
            <input type="date"
                   class="form-control form-control-sm"
                   @bind="_fechaTemp"
                   max="@DateTime.Today.ToString("yyyy-MM-dd")" />
        </div>

        <div class="search-actions">
            <button class="btn btn-primary" disabled="@(_fechaTemp is null || _loading)" @onclick="EjecutarBusqueda">
                🔍 Buscar
            </button>

            @if (_fechaBusqueda is not null)
            {
                <button class="btn btn-ghost" @onclick="LimpiarBusqueda">
                    🧹 Limpiar
                </button>
            }
        </div>

        @if (_response is not null && _response.Items.Any())
        {
            <div class="results-header">
                <div class="results-header-left">
                    <span class="results-date">
                        📅 @_fechaBusqueda!.Value.ToString("dddd dd \\d\\e MMMM yyyy", new System.Globalization.CultureInfo("es-PE"))
                    </span>
                </div>
            </div>

            <div class="results-butons-header">
                @foreach (OrderStatus item in Enum.GetValues(typeof(OrderStatus)))
                {
                    <button class="btn btn-ghost" @onclick="LimpiarBusqueda">
                        @item.ToString()
                    </button>
                }

                <!-- Mini resumen de estados -->
                <div class="results-stats">
                    @{
                        var entregados = _response.Items.Count(p => p.OrderStatus == OrderStatus.Delivered);
                        var fallidos = _response.Items.Count(p => p.OrderStatus == OrderStatus.Failed);
                        var ausentes = _response.Items.Count(p => p.OrderStatus == OrderStatus.RecipientAbsent);
                        var retorno = _response.Items.Count(p => p.OrderStatus == OrderStatus.Returning);
                    }
                    @if (entregados > 0)
                    {
                        <span class="res-stat res-stat--success">✅ @entregados</span>
                    }
                    @if (fallidos > 0)
                    {
                        <span class="res-stat res-stat--danger">❌ @fallidos</span>
                    }
                    @if (ausentes > 0)
                    {
                        <span class="res-stat res-stat--warning">🚪 @ausentes</span>
                    }
                    @if (retorno > 0)
                    {
                        <span class="res-stat res-stat--info">↩️ @retorno</span>
                    }
                </div>
            </div>
        }
    </div>
</div>

<!-- ── IDLE ── -->
@if (_fechaBusqueda is null)
{
    <div class="idle-state">
        <div class="idle-icon">🚚</div>
        <h2 class="idle-title">Consulta tus entregas</h2>
        <p class="idle-subtitle">Selecciona una fecha para ver los pedidos gestionados ese día.</p>
    </div>
}
else if (_loading)
{
    <div class="loading-overlay">
        <div class="spinner"></div>
        <span>Buscando entregas para @_fechaBusqueda.Value.ToString("dd/MM/yyyy")…</span>
    </div>
}
else if (_response is null || !_response.Items.Any())
{
    <div class="empty-state">
        <span class="empty-icon">📭</span>
        <p class="text-bold">Sin entregas para el @_fechaBusqueda.Value.ToString("dd/MM/yyyy")</p>
        <p class="text-muted">No se encontraron pedidos con los filtros seleccionados.</p>
    </div>
}
else
{
    <div class="entregas-list">
        @foreach (var pedido in _response.Items)
        {
            <details class="carga-detail-card @($"carga--{pedido.OrderStatus}")" open="@(_expandedId == pedido.Id)">
                <summary class="carga-detail-summary" @onclick="() => ToggleExpand(pedido.Id)" @onclick:preventDefault="true">
                    <div class="carga-detail-chevron">
                        @(_expandedId == pedido.Id ? "▾" : "▸")
                    </div>

                    <div class="carga-detail-header-info">
                        <div class="carga-detail-title">
                            <span class="codigo-seguimiento">@pedido.TrackingCode</span>
                            <BadgeEstado Estado="@pedido.OrderStatus" />
                        </div>

                        <div class="entrega-card-nombre">@pedido.RecipientName</div>
                    </div>
                    
                    @if (pedido.CargaId.HasValue)
                    {
                        <span class="entrega-carga-ref">📋 Carga #@pedido.CargaId</span>
                    }
                </summary>

                <div class="carga-detail-body">
                    <div class="carga-info-grid">
                        <div class="carga-info-item carga-info-item--wide">
                            <span class="carga-info-label">Dirección</span>
                            <span>@pedido.RecipientAddress, @pedido.RecipientDistrict</span>
                        </div>
                        <div class="carga-info-item">
                            <span class="carga-info-label">Teléfono</span>
                            <span>@pedido.RecipientPhone</span>
                        </div>
                        <div class="carga-info-item">
                            <span class="carga-info-label">Empresa</span>
                            <span>@pedido.CompanyName</span>
                        </div>
                        <div class="carga-info-item">
                            <span class="carga-info-label">Paquete</span>
                            <span>@pedido.PackageDescription (@pedido.Quantity u.)</span>
                        </div>
                        <div class="carga-info-item">
                            <span class="carga-info-label">Registro</span>
                            <span>@pedido.RegistrationDate.ToString("dd/MM/yyyy")</span>
                        </div>
                        @if (pedido.DeliveryDate.HasValue)
                        {
                            <div class="carga-info-item">
                                <span class="carga-info-label">Entregado</span>
                                <span class="carga-info-value--success">@pedido.DeliveryDate.Value.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                        }
                    </div>

                    <!-- ── FOOTER: intentos fallidos ── -->
                    @if (pedido.DeliveryAttempts > 0)
                    {
                        <div class="entrega-card-footer">
                            <span class="pedido-card-intentos">⚠️ @pedido.DeliveryAttempts intento(s) fallido(s)</span>
                        </div>
                    }
                </div>
            </details>
        }
    </div>

    <!-- Paginación -->
    @if (_response.TotalPages > 1)
    {
        <div class="entregas-paginacion">
            <button class="btn btn-ghost btn-sm"
                    disabled="@(_page <= 1 || _loading)"
                    @onclick="() => CambiarPagina(_page - 1)">
                ← Anterior
            </button>

            @for (int i = 1; i <= _response.TotalPages; i++)
            {
                var pageNum = i;
                <button class="btn btn-sm @(pageNum == _page ? "btn-primary" : "btn-ghost")"
                        disabled="@_loading"
                        @onclick="() => CambiarPagina(pageNum)">
                    @pageNum
                </button>
            }

            <button class="btn btn-ghost btn-sm"
                    disabled="@(_page >= _response.TotalPages || _loading)"
                    @onclick="() => CambiarPagina(_page + 1)">
                Siguiente →
            </button>
        </div>
    }

    <p class="entregas-info-pagina text-muted text-xs">
        Mostrando @((_page - 1) * _pageSize + 1)–@(Math.Min(_page * _pageSize, _response.TotalItems))
        de @_response.TotalItems resultado(s)
    </p>
}

@code {
    private MyDeliveriesResponseDTO? _response;
    private bool _loading;
    private int _page = 1;
    private int _pageSize = 10;
    private DateTime? _fechaTemp;
    private string _statusTemp = "";
    private DateTime? _fechaBusqueda;
    private OrderStatus? _statusFiltro;
    private int? _expandedId;


    private async Task LoadAsync()
    {
        if (_fechaBusqueda is null) return;

        _loading = true;
        StateHasChanged();

        _response = await _DriverService.GetMyDeliveriesAsync(
            page: _page,
            pageSize: _pageSize,
            desde: _fechaBusqueda.Value.Date,
            hasta: _fechaBusqueda.Value.Date.AddDays(1).AddSeconds(-1));

        _loading = false;
    }

    private async Task EjecutarBusqueda()
    {
        if (_fechaTemp is null) return;

        _page = 1;
        _fechaBusqueda = _fechaTemp;
        _statusFiltro = string.IsNullOrEmpty(_statusTemp)
            ? null
            : Enum.Parse<OrderStatus>(_statusTemp);

        await LoadAsync();
    }

    private void ToggleExpand(int id) => _expandedId = _expandedId == id ? null : id;

    private async Task CambiarPagina(int nuevaPagina)
    {
        _page = nuevaPagina;
        await LoadAsync();
    }

    private Task LimpiarBusqueda()
    {
        _page = 1;
        _fechaTemp = null;
        _statusTemp = "";
        _fechaBusqueda = null;
        _statusFiltro = null;
        _response = null;
        return Task.CompletedTask;
    }
}
