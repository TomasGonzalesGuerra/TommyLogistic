@using Blazored.LocalStorage
@using TommyLogistic.Shared.Models
@inject IJSRuntime JS
@implements IDisposable
@inject TourService _TourService
@inject ILocalStorageService LocalStorage
@inject AuthenticationStateProvider _AuthProvider

@if (_TourService.IsActive && _TourService.Current != null)
{
    @* El overlay SOLO existe cuando el tour está activo *@
    <div class="tour-overlay"></div>
    <div class="tour-spotlight" id="tour-spotlight"></div>

    <div class="tour-mascot" id="tour-mascot" style=@($"left:{mascotX}px; top:{mascotY}px;")>
        <div class="mascot-body mascot-mood--@_TourService.Current.Mood.ToString().ToLower()">
            @RobotSvg(_TourService.Current.Mood)
        </div>
    </div>

    <!-- Bocadillo -->
    <div class="tour-bubble tour-bubble--@(_TourService.Current.BubblePos.ToString().ToLower())"
         id="tour-bubble" style=@($"left:{bubbleX}px; top:{bubbleY}px;")>

        <div class="tour-bubble-header">
            <span class="tour-step-counter">@(_TourService.CurrentStep + 1) / @_TourService.TotalSteps</span>
            <button class="tour-skip" @onclick="SkipTour">Saltar tour</button>
        </div>

        <h3 class="tour-bubble-title">@_TourService.Current.Title</h3>
        <p class="tour-bubble-message">@_TourService.Current.Message</p>

        <div class="tour-progress">
            @for (int i = 0; i < _TourService.TotalSteps; i++)
            {
                <div class="tour-dot @(i == _TourService.CurrentStep ? "active" : i < _TourService.CurrentStep ? "done" : "")"></div>
            }
        </div>

        <div class="tour-bubble-actions">
            @if (!_TourService.IsFirstStep)
            {
                <button class="tour-btn tour-btn--ghost" @onclick="Previous">
                    ← Anterior
                </button>
            }
            else
            {
                <span></span>
            }

            @if (_TourService.IsLastStep)
            {
                <button class="tour-btn tour-btn--primary" @onclick="FinishTour">
                    ¡Entendido! 🎉
                </button>
            }
            else
            {
                <button class="tour-btn tour-btn--primary" @onclick="Next">
                    Siguiente →
                </button>
            }
        </div>
    </div>
}


@code {
    private double mascotX = 40;
    private double mascotY = 400;
    private double bubbleX = 160;
    private double bubbleY = 380;
    private string userRole = "";

    protected override void OnInitialized()
    {
        _TourService.OnChange += HandleTourChange;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var authState = await _AuthProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                userRole = user.FindFirst("role")?.Value ?? "";

                // Leer localStorage desde el componente (Scoped ✅)
                var key = $"tour_done_{userRole.ToLower()}";
                var done = await LocalStorage.GetItemAsync<bool>(key);

                _TourService.TryStartTour(userRole, done);
            }
        }

        if (_TourService.IsActive && _TourService.Current != null)
            await PositionElements();
    }

    private async Task PositionElements()
    {
        if (_TourService.Current == null) return;

        try
        {
            var rect = await JS.InvokeAsync<ElementRect>("tourGetElementRect",
                _TourService.Current.TargetSelector);

            if (rect == null) return;

            // Spotlight encima del elemento
            await JS.InvokeVoidAsync("tourSetSpotlight", rect.Left - 8, rect.Top - 8,
                rect.Width + 16, rect.Height + 16);

            // Mascota: se pone cerca del elemento
            mascotX = rect.Left + rect.Width / 2 - 45;
            mascotY = rect.Top - 120;

            // Bocadillo según posición preferida
            switch (_TourService.Current.BubblePos)
            {
                case BubblePosition.Right:
                    bubbleX = rect.Left + rect.Width + 20;
                    bubbleY = rect.Top + rect.Height / 2 - 100;
                    mascotX = rect.Left + rect.Width + 20;
                    mascotY = rect.Top + rect.Height / 2 - 200;
                    break;
                case BubblePosition.Left:
                    bubbleX = rect.Left - 320;
                    bubbleY = rect.Top + rect.Height / 2 - 100;
                    mascotX = rect.Left - 120;
                    mascotY = rect.Top + rect.Height / 2 - 200;
                    break;
                case BubblePosition.Bottom:
                    bubbleX = rect.Left + rect.Width / 2 - 150;
                    bubbleY = rect.Top + rect.Height + 24;
                    mascotX = rect.Left + rect.Width / 2 - 45;
                    mascotY = rect.Top + rect.Height + 130;
                    break;
                case BubblePosition.Top:
                    bubbleX = rect.Left + rect.Width / 2 - 150;
                    bubbleY = rect.Top - 220;
                    mascotX = rect.Left + rect.Width / 2 - 45;
                    mascotY = rect.Top - 330;
                    break;
            }

            // Clamp para que no salga de pantalla
            var vw = await JS.InvokeAsync<double>("tourGetViewportWidth");
            var vh = await JS.InvokeAsync<double>("tourGetViewportHeight");

            bubbleX = Math.Max(16, Math.Min(bubbleX, vw - 316));
            bubbleY = Math.Max(16, Math.Min(bubbleY, vh - 280));
            mascotX = Math.Max(8, Math.Min(mascotX, vw - 100));
            mascotY = Math.Max(8, Math.Min(mascotY, vh - 140));

            StateHasChanged();
        }
        catch { /* elemento no encontrado, siguiente step */ }
    }

    private async void HandleTourChange()
    {
        await InvokeAsync(async () =>
        {
            StateHasChanged();
            await Task.Delay(60); // esperar render
            await PositionElements();
        });
    }

    private async Task Next()
    {
        _TourService.Next();
        await PositionElements();
    }

    private async Task Previous()
    {
        _TourService.Previous();
        await PositionElements();
    }
    
    private async Task FinishTour()
    {
        // Guardar en localStorage desde el componente (Scoped ✅)
        var key = $"tour_done_{userRole.ToLower()}";
        await LocalStorage.SetItemAsync(key, true);
        _TourService.Finish();
    }

    private async Task SkipTour() => await FinishTour();

    public void Dispose() => _TourService.OnChange -= HandleTourChange;

    // SVG del robotito según mood
    private RenderFragment RobotSvg(MascotMood mood) => __builder =>
