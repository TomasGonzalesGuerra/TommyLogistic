@code {
    private readonly List<ToastItem> _toasts = [];
    private bool _inicializado;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _inicializado) return;
        _inicializado = true;

        // Usamos SesionService tal cual lo tienes
        var rol = await _SesionService.GetRolAsync();
        if (rol is null) return; // no hay sesión activa, no conectar

        // El userId viene del ClaimTypes.NameIdentifier (el "sub" del JWT = IdentityUser.Id)
        var user = await _SesionService.ObtenerUsuarioAsync();
        var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
                  ?? user.FindFirst("sub")?.Value;

        if (userId is null) return;

        // Suscribir eventos ANTES de llamar StartAsync
        _NotificationService.OnNewDriver += HandleNewDriver;
        _NotificationService.OnNewOrder  += HandleNewOrder;

        // Iniciar la conexión pasando rol y userId
        await _NotificationService.StartAsync(rol, userId);
    }

    private void HandleNewDriver(string _)
    {
        // Mostramos un mensaje fijo; el payload JSON viene en _ si lo necesitas parsear
        AddToast("🛵", "¡Tienes un nuevo compañero repartidor!");
    }

    private void HandleNewOrder(string _)
    {
        AddToast("📦", "¡Te asignaron un nuevo pedido!");
    }

    private void AddToast(string icon, string message)
    {
        var toast = new ToastItem(icon, message);
        _toasts.Add(toast);
        InvokeAsync(StateHasChanged);

        // Auto-cerrar a los 5 segundos
        _ = Task.Delay(5000).ContinueWith(_ =>
        {
            Remove(toast);
            InvokeAsync(StateHasChanged);
        });
    }

    private void Remove(ToastItem toast)
    {
        _toasts.Remove(toast);
        InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        _NotificationService.OnNewDriver -= HandleNewDriver;
        _NotificationService.OnNewOrder  -= HandleNewOrder;
        await _NotificationService.DisposeAsync();
    }

    private record ToastItem(string Icon, string Message)
    {
        public DateTime Time { get; } = DateTime.Now;
    }
}