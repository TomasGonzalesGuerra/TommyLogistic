@* TommyLogistic.Web/Components/Shared/NotificationToast.razor *@
@implements IAsyncDisposable
@inject NotificationService _NotificationService
@inject SesionService _SesionService

<div class="toast-container">
    @foreach (var toast in _toasts)
    {
        <div class="toast-item">
            <span class="toast-icon">@toast.Icon</span>
            <div class="toast-body">
                <p class="toast-message">@toast.Message</p>
                <span class="toast-time">@toast.Time.ToShortTimeString()</span>
            </div>
            <button class="toast-close" @onclick="() => Remove(toast)">✕</button>
        </div>
    }
</div>

