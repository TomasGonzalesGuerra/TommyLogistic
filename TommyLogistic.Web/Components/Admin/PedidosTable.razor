@using System.Linq

<div class="pedidos-table-wrapper">

    <!-- Barra superior: búsqueda + conteo -->
    <div class="pedidos-table__toolbar">
        <div class="pedidos-table__search">
            <span class="pedidos-table__search-icon">🔍</span>
            <input class="form-control pedidos-table__input"
                   type="search"
                   placeholder="Buscar por código o destinatario…"
                   @bind="_busqueda"
                   @bind:event="oninput" />
        </div>
        <span class="text-muted text-sm">@Paginados.Count() de @Filtrados.Count() pedidos</span>
    </div>

    <!-- Tabla -->
    <div class="table-wrapper">
        <table class="table">
            <thead>
                <tr>
                    <th>Tracking</th>
                    <th>Destinatario</th>
                    <th class="hide-mobile">Dirección</th>
                    <th>Estado</th>
                    <th class="hide-mobile">Fecha</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (!Paginados.Any())
                {
                    <tr>
                        <td colspan="6">
                            <div class="pedidos-table__empty">
                                <span>📦</span>
                                <p>No se encontraron pedidos</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var p in Paginados)
                    {
                        <tr @onclick="() => OnVerDetalle.InvokeAsync(p.Id)">
                            <td>
                                <span class="pedidos-table__tracking">@p.TrackingCode</span>
                            </td>
                            <td>@p.RecipientName</td>
                            <td class="hide-mobile text-muted text-sm">@p.RecipientDistrict</td>
                            <td><span class="badge badge-@p.OrderStatus.ToString().ToLower()">@p.OrderStatus</span></td>
                            <td class="hide-mobile text-muted text-sm">
                                @p.RegistrationDate.ToString("dd/MM/yyyy")
                            </td>
                            <td>
                                <button class="btn btn-ghost btn-sm"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => OnVerDetalle.InvokeAsync(p.Id)">
                                    Ver
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Paginación -->
    @if (TotalPaginas > 1)
    {
        <div class="pedidos-table__pagination">
            <button class="btn btn-ghost btn-sm"
                    disabled="@(_pagina <= 1)"
                    @onclick="() => _pagina--">
                ← Anterior
            </button>

            <span class="text-sm text-muted">
                Página @_pagina de @TotalPaginas
            </span>

            <button class="btn btn-ghost btn-sm"
                    disabled="@(_pagina >= TotalPaginas)"
                    @onclick="() => _pagina++">
                Siguiente →
            </button>
        </div>
    }

</div>

@code {
    [Parameter, EditorRequired] public List<OrderSummaryDTO> Pedidos { get; set; } = [];
    [Parameter] public int PageSize { get; set; } = 10;
    [Parameter] public EventCallback<int> OnVerDetalle { get; set; }

    private string _busqueda = "";
    private int _pagina = 1;

    private IEnumerable<OrderSummaryDTO> Filtrados => string.IsNullOrWhiteSpace(_busqueda)
        ? Pedidos
        : Pedidos.Where(p =>
            p.TrackingCode.Contains(_busqueda, StringComparison.OrdinalIgnoreCase) ||
            p.RecipientName.Contains(_busqueda, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<OrderSummaryDTO> Paginados =>
        Filtrados.Skip((_pagina - 1) * PageSize).Take(PageSize);

    private int TotalPaginas =>
        (int)Math.Ceiling(Filtrados.Count() / (double)PageSize);

    // Resetear página al cambiar búsqueda
    private string BusquedaProxy
    {
        get => _busqueda;
        set { _busqueda = value; _pagina = 1; }
    }
}
