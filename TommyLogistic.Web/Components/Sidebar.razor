@inject IJSRuntime _IJSRuntime
@inject ILoginService _ILoginService
@inject NavigationManager _NavigationManager

<div class="sidebar-inner">

    <div class="sidebar-header">
        <div class="sidebar-logo">
            <span class="logo-mark">TD</span>
            <span class="logo-name">TommyLogistic</span>
        </div>
        <button class="sidebar-close" @onclick="OnCerrar" aria-label="Cerrar menú">✕</button>
    </div>

    <nav class="sidebar-nav">
        <AuthorizeView Roles="Admin">
            <div class="nav-section-label">Operaciones</div>
            <NavLink class="this" href="/AdminDashboard">
                <span class="nav-icon">📊</span> Dashboard
            </NavLink>
            <NavLink class="this" href="/Orders">
                <span class="nav-icon">📦</span> Pedidos
            </NavLink>
            <NavLink class="this" href="/Warehouses">
                <span class="nav-icon">🏭</span> Almacén
            </NavLink>

            <div class="nav-section-label">Gestión</div>
            <NavLink class="this" href="/Companies">
                <span class="nav-icon">🏢</span> Empresas
            </NavLink>
            <NavLink class="this" href="/Drivers">
                <span class="nav-icon">🛵</span> Repartidores
            </NavLink>
        </AuthorizeView>

        <AuthorizeView Roles="ClienteEmpresa">
            <div class="nav-section-label">Mi empresa</div>
            <div class="this" href="/" Match="divMatch.All">
                <span class="nav-icon">📊</span> Dashboard
            </div>
            <div class="this" href="/mis-pedidos">
                <span class="nav-icon">📦</span> Mis pedidos
            </div>
            <div class="this" href="/mis-pedidos/nuevo">
                <span class="nav-icon">➕</span> Nuevo pedido
            </div>
        </AuthorizeView>

        <AuthorizeView Roles="Repartidor">
            <div class="nav-section-label">Mi ruta</div>
            <div class="this" href="/" Match="divMatch.All">
                <span class="nav-icon">🗺️</span> Mi ruta
            </div>
            <div class="this" href="/mis-entregas">
                <span class="nav-icon">✅</span> Mis entregas
            </div>
        </AuthorizeView>

    </nav>

    <div class="sidebar-footer">
        <button class="btn btn-ghost w-full" @onclick="Logout">
            <span>🚪</span> Log Out
        </button>

        <button class="btn-theme" @onclick="ToggleTheme">
            <span>@(isDarkMode ? "☀️" : "🌙")</span>
        </button>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnCerrar { get; set; }
    private bool isDarkMode;
    private bool active;


    protected override void OnInitialized()
    {
        _NavigationManager.LocationChanged += (s, e) => StateHasChanged();
    }

    private string IsActive(string href)
    {
        return _NavigationManager.Uri.EndsWith(href, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }

    private async Task Logout()
    {
        await _ILoginService.LogoutAsync();
        _NavigationManager.NavigateTo("/", forceLoad: true);
    }

    private async Task ToggleTheme()
    {
        isDarkMode = !isDarkMode;
        
        if (isDarkMode)
        {
            await _IJSRuntime.InvokeVoidAsync("document.body.classList.add", "dark");
            await _IJSRuntime.InvokeVoidAsync("localStorage.setItem", "theme", "dark");
        }
        else
        {
            await _IJSRuntime.InvokeVoidAsync("document.body.classList.remove", "dark");
            await _IJSRuntime.InvokeVoidAsync("localStorage.setItem", "theme", "light");
        }
    }
}