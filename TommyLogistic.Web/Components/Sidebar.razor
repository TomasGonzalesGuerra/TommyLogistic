@inject IJSRuntime _IJSRuntime
@inject ILoginService _ILoginService
@inject NavigationManager _NavigationManager
@inject ComingSoonService _ComingSoonService

<div class="sidebar-inner">

    <div class="sidebar-header">
        <div class="sidebar-logo">
            <span class="logo-mark">TL</span>
            <span class="logo-name">Tommy Logistic</span>
        </div>
        <button class="sidebar-close" @onclick="OnCerrar" aria-label="Cerrar menú">✕</button>
    </div>

    <nav class="sidebar-nav" aria-label="Navegación principal">

        <AuthorizeView Roles="@nameof(UserEnum.Admin)">
            <div class="nav-section-label">Operaciones</div>
            <NavLink class="this" href="/AdminDashboard" Match="NavLinkMatch.All">
                <span class="nav-icon">📊</span> Dashboard
            </NavLink>
            <NavLink class="this" href="/Orders">
                <span class="nav-icon">📦</span> Pedidos
            </NavLink>
            <NavLink class="this" href="/Drivers">
                <span class="nav-icon">🛵</span> Repartidores
            </NavLink>
            <NavLink class="this" href="/Warehouses">
                <span class="nav-icon">🏭</span> Almacén
            </NavLink>
            <NavLink class="this" href="/Loads">
                <span class="nav-icon">➕</span> Cargas
            </NavLink>
            <div class="nav-section-label">Gestión</div>
            <NavLink class="this" href="/Companies">
                <span class="nav-icon">🏢</span> Empresas
            </NavLink>
            <NavLink class="this" @onclick="_ComingSoonService.Show">
                <span class="nav-icon">📊</span> Reportes
            </NavLink>
        </AuthorizeView>

        <AuthorizeView Roles="@nameof(UserEnum.Supervisor)">
            <div class="nav-section-label">Supervisión</div>
            <NavLink class="this" href="/SupervisorDashboard" Match="NavLinkMatch.All">
                <span class="nav-icon">📊</span> Dashboard
            </NavLink>
            <NavLink class="this" href="/Orders">
                <span class="nav-icon">📦</span> Pedidos
            </NavLink>
            <NavLink class="this" href="/Loads">
                <span class="nav-icon">➕</span> Cargas
            </NavLink>
        </AuthorizeView>

        <AuthorizeView Roles="@nameof(UserEnum.Operator)">
            <div class="nav-section-label">Operador</div>
            <NavLink class="this" href="/OperatorDashboard" Match="NavLinkMatch.All">
                <span class="nav-icon">📊</span> Dashboard
            </NavLink>
            <NavLink class="this" href="/Orders">
                <span class="nav-icon">📦</span> Pedidos
            </NavLink>
            <NavLink class="this" href="/LoadsPage">
                <span class="nav-icon">➕</span> Cargas
            </NavLink>
        </AuthorizeView>

        <AuthorizeView Roles="@nameof(UserEnum.Client)">
            <div class="nav-section-label">Mi empresa</div>
            <NavLink class="this" href="/ClientDashboard" Match="NavLinkMatch.All">
                <span class="nav-icon">📊</span> Dashboard
            </NavLink>
            <NavLink class="this" href="/mis-pedidos">
                <span class="nav-icon">📦</span> Mis pedidos
            </NavLink>
            <NavLink class="this" href="/mis-pedidos/nuevo">
                <span class="nav-icon">➕</span> Nuevo pedido
            </NavLink>
        </AuthorizeView>

        <AuthorizeView Roles="@nameof(UserEnum.Driver)">
            <div class="nav-section-label">Mi ruta</div>
            <NavLink class="this" href="/DriverDashboard" Match="NavLinkMatch.All">
                <span class="nav-icon">🗺️</span> Mi ruta
            </NavLink>
            <NavLink class="this" href="/Driver/Load">
                <span class="nav-icon">🗺️</span> Mi Carga
            </NavLink>
            <NavLink class="this" href="/Driver/Deliveries">
                <span class="nav-icon">✅</span> Mis Entregas
            </NavLink>
            <NavLink class="this" href="/Driver/Scan">
                <span class="nav-icon">📷</span> Escanear
            </NavLink>
            <NavLink class="this" href="/Driver/Profile">
                <span class="nav-icon">👤</span> Mi Perfil
            </NavLink>
        </AuthorizeView>

    </nav>

    <div class="sidebar-footer">
        <button class="btn btn-ghost w-full sidebar-logout" @onclick="Logout">
            <span>🚪</span> Salir
        </button>
        <button class="btn-theme" @onclick="ToggleTheme" title="@(isDarkMode ? "Modo claro" : "Modo oscuro")">
            @(isDarkMode ? "☀️" : "🌙")
        </button>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnCerrar { get; set; }
    private bool isDarkMode = false;

    protected override async Task OnInitializedAsync()
    {
        _NavigationManager.LocationChanged += (s, e) => InvokeAsync(StateHasChanged);
        // Leer preferencia guardada
        var saved = await _IJSRuntime.InvokeAsync<string?>("localStorage.getItem", "theme");
        isDarkMode = saved == "dark";
        await ApplyTheme();
    }

    private async Task Logout()
    {
        await _ILoginService.LogoutAsync();
        _NavigationManager.NavigateTo("/", forceLoad: true);
    }

    private async Task ToggleTheme()
    {
        isDarkMode = !isDarkMode;
        await ApplyTheme();
    }

    private async Task ApplyTheme()
    {
        if (isDarkMode)
        {
            await _IJSRuntime.InvokeVoidAsync("document.body.classList.add", "dark");
            await _IJSRuntime.InvokeVoidAsync("localStorage.setItem", "theme", "dark");
        }
        else
        {
            await _IJSRuntime.InvokeVoidAsync("document.body.classList.remove", "dark");
            await _IJSRuntime.InvokeVoidAsync("localStorage.setItem", "theme", "light");
        }
    }
}
