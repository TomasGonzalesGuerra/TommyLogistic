{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/_framework/*",
      "/css/*",
      "/js/*",
      "/*.json",
      "/*.ico",
      "/*.png",
      "/*.js"
    ]
  },
  "mimeTypeOverrides": {
    ".js": "application/javascript",
    ".wasm": "application/wasm"
  }
}
