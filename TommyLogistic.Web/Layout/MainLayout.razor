@inherits LayoutComponentBase
@implements IDisposable
@inject SesionService _SesionService
@inject NavigationManager _NavigationManager
@inject ComingSoonService _ComingSoonService

<div class="app-layout">
    @if (_inicializando)
    {
        <div class="splash-loader">
            <div class="splash-logo">TD</div>
            <div class="splash-spinner"></div>
            <p>Cargando...</p>
        </div>
    }
    else
    {
        <nav class="app-sidebar @(_sidebarAbierto ? "open" : "")">
            <Sidebar OnCerrar="CerrarSidebar" />
        </nav>

        @if (_sidebarAbierto)
        {
            <div class="sidebar-overlay" @onclick="CerrarSidebar"></div>
        }

        <div class="app-main">
            <header class="app-topbar">
                <button class="btn-hamburger" @onclick="ToggleSidebar" aria-label="Menú">
                    <span></span><span></span><span></span>
                </button>
                <div class="topbar-logo">
                    <span class="logo-mark">TL</span>
                    <span class="logo-text hide-mobile">Tommy Logistics</span>
                </div>
                <div class="topbar-right">
                    <NotificationBell />
                    <span class="topbar-rol badge @BadgeRol">@_rol</span>
                    <span class="topbar-nombre hide-mobile">@_nombre.Split('@')[0]</span>
                    <img class="topbar-photo hide-mobile" src="@_photo" alt="Foto de perfil" />
                </div>
            </header>

            <main class="app-content">
                <NotificationToast />
                @Body
            </main>
        </div>
    }
</div>

<ComingSoonModal @bind-IsVisible="_ComingSoonService.IsVisible" />


@code {
    private bool   _inicializando   = true;
    private bool   _sidebarAbierto;
    private string _rol    = string.Empty;
    private string _nombre = string.Empty;
    private string _photo = string.Empty;
    private string BadgeRol => _rol switch
    {
        "Admin" => "badge-encamino",
        "Supervisor" => "badge-asignado",
        "Operator" => "badge-retirado",
        "Driver" => "badge-retirado",
        "Client" => "badge-retirado",
        _ => "badge-registrado"
    };


    protected override async Task OnInitializedAsync()
    {
        _rol = await _SesionService.GetRolAsync() ?? string.Empty;
        _nombre = await _SesionService.GetNameAsync() ?? string.Empty;
        _photo = await _SesionService.GetPhotoAsync() ?? string.Empty;
        _inicializando = false;
        _ComingSoonService.OnChange += StateHasChanged;
    }

    private void CerrarSidebar() => _sidebarAbierto = false;
    private void ToggleSidebar() => _sidebarAbierto = !_sidebarAbierto;
    public void Dispose()
    {
        _ComingSoonService.OnChange -= StateHasChanged;
    }

}
